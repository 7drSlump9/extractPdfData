{
  "name": "CND_JOY_ORDINE",
  "description": "Ordine cliente Consorzio Nazionale Dettaglianti (CND) indirizzato a JOY SRL. Intestazione con blocco 'Spettabile' in alto a destra, blocco 'Cliente cui fatturare' a sinistra, dati ordine (Nr./Del/Settore) a destra. Tabella articoli con righe multi-linea (riga principale + righe di dettaglio PZxCT/Flusso/Gestione/PL/Scorta) e piede 'T O T A L I'.",
  "signature": [
    "Consorzio Nazionale Dettaglianti",
    "PZxCT:",
    "T O T A L I"
  ],
  "header_fields": {
    "numero_ordine": {
      "type": "regex_full_text",
      "pattern": "Ordine Nr\\.:\\s*(\\d+)",
      "group": 1
    },
    "data": {
      "type": "regex_full_text",
      "pattern": "Del:\\s*(\\d{2}/\\d{2}/\\d{2})",
      "group": 1
    },
    "partita_iva_cliente": {
      "type": "regex_column_filtered",
      "pattern": "Partita\\s+IVA\\s+(\\d+)",
      "x_min": 0,
      "x_max": 200,
      "group": 1
    }
  },
  "table": {
    "start_after_contains": [
      "Riga",
      "EAN",
      "Codice",
      "Descrizione",
      "Quantità"
    ],
    "end_markers": [
      "T O T A L I",
      "TOTALI"
    ],
    "row_detect_pattern": "^\\d+\\s+\\d{10,14}\\s+\\d+\\s+",
    "skip_line_if_matches": "^(PZxCT:|Flusso:|Gestione:|PL\\s|CT\\s+\\d)",
    "columns": [
      {
        "name": "riga",
        "x_min": 0,
        "x_max": 45,
        "value": "first_word"
      },
      {
        "name": "ean",
        "x_min": 45,
        "x_max": 105,
        "value": "first_word"
      },
      {
        "name": "codice",
        "x_min": 105,
        "x_max": 170,
        "value": "first_word"
      },
      {
        "name": "descrizione",
        "x_min": 170,
        "x_max": 330,
        "value": "joined_text"
      },
      {
        "name": "unita_misura",
        "x_min": 330,
        "x_max": 360,
        "value": "unit_prefix"
      },
      {
        "name": "quantita",
        "x_min": 355,
        "x_max": 400,
        "value": "numeric"
      },
      {
        "name": "costo_netto",
        "x_min": 590,
        "x_max": 650,
        "value": "numeric"
      },
      {
        "name": "listino",
        "x_min": 650,
        "x_max": 695,
        "value": "first_word"
      },
      {
        "name": "importo_riga",
        "x_min": 695,
        "x_max": 745,
        "value": "numeric"
      },
      {
        "name": "iva",
        "x_min": 745,
        "x_max": 770,
        "value": "numeric"
      }
    ],
    "continuation_join_field": "dettagli"
  }
}